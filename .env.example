# Required
FISH_API_KEY=your_fish_api_key

# Optional — for music/ambient generation and mixing
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional — Pydantic AI agent via OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_API_TTS_PROMPT_MODEL=google/gemini-2.5-flash
# PYDANTIC_AI_MODEL=openrouter:google/gemini-2.5-flash

# Optional — OpenTelemetry tracing export
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=smart-tts
# OTEL_TRACES_CONSOLE=1

# Optional — synthesis timeout for run_synthesize_speech (seconds; empty = no default)
# SMART_TTS_SYNTHESIS_TIMEOUT_SEC=

# Optional
# Use s2.1-pro-free if you have no paid Fish credits (skips 402 fallback)
FISH_DEFAULT_MODEL=s2.1-pro
FISH_DEFAULT_VOICE_ID=67d37d81cb7340b391e9461d6671de03
ELEVENLABS_CACHE_DIR=~/.cache/smart-tts
ELEVENLABS_DEFAULT_OUTPUT_FORMAT=mp3_44100_128
FISH_API_URL=https://api.fish.audio/v1/tts
